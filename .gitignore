# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Backend runtime data — created by `cargo run -p minos-backend` or
# `MINOS_BACKEND_DB=sqlite://./minos-backend.db` against the dev defaults.
minos-backend.db
minos-backend.db-journal
minos-backend.db-wal
minos-backend.db-shm

# IDE
.idea/
.vscode/
*.iml
.DS_Store

# UniFFI / frb generated artifacts.
#
# `apps/mobile/lib/src/rust/**` and `crates/minos-ffi-frb/src/frb_generated.rs`
# ARE checked in (per spec §10.3 and plan 03 Phase C): CI's Dart leg runs
# without a Rust toolchain, so the generated bindings must be present in
# source control. Regenerate with `flutter_rust_bridge_codegen generate`.
#
# `apps/mobile/rust_builder/` ships the vendored cargokit plugin shim that
# compiles the Rust static lib at `flutter build ios` time — also committed.
# Only its build-time artifacts are ignored below.
apps/macos/Minos/Generated/
apps/macos/Minos.xcodeproj/
apps/macos/Brewfile.lock.json
apps/mobile/.dart_tool/
apps/mobile/build/
apps/mobile/rust_builder/cargokit/build_tool/.dart_tool/
apps/mobile/rust_builder/**/.package_hash
apps/mobile/rust_builder/**/*.dill

# Logs
*.log
*.xlog

# Flutter / Dart (apps/mobile)
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/.fvm/
apps/mobile/build/
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/ios/Flutter/Flutter.framework
apps/mobile/ios/Flutter/Flutter.podspec
apps/mobile/ios/Flutter/ephemeral/
apps/mobile/ios/Flutter/flutter_export_environment.sh
apps/mobile/ios/Flutter/Generated.xcconfig
apps/mobile/ios/Runner/GeneratedPluginRegistrant.*
apps/mobile/android/.gradle/
apps/mobile/android/local.properties
apps/mobile/android/captures/
apps/mobile/android/key.properties
apps/mobile/android/**/gradle-wrapper.jar

